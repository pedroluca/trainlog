rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.isAdmin == true;
    }

    function trainerRelationId(trainerId, studentId) {
      return trainerId + '_' + studentId;
    }

    function hasAcceptedTrainerRelation(trainerId, studentId) {
      return exists(/databases/$(database)/documents/trainer_relations/$(trainerRelationId(trainerId, studentId))) &&
             get(/databases/$(database)/documents/trainer_relations/$(trainerRelationId(trainerId, studentId))).data.status == 'accepted';
    }
    
    // sistema collection (for app version tracking)
    match /sistema/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // usuarios collection
    match /usuarios/{userId} {
      // Allow any authenticated user to read profiles (needed for friends search)
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    
    // registrationRequests collection
    match /registrationRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if true; // Allow anyone to create registration requests
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // upgrade_requests collection (Premium upgrade requests)
    match /upgrade_requests/{requestId} {
      // Users can create their own upgrade requests
      allow create: if request.auth != null && 
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.status == 'pending';
      
      // Users can read their own requests
      allow read: if request.auth != null && 
                     (resource.data.userId == request.auth.uid || isAdmin());
      
      // Only admins can update/delete upgrade requests
      allow update, delete: if isAdmin();
    }
    
    // treinos collection
    match /treinos/{treinoId} {
      // Allow read if:
      // 1. User owns the workout, OR
      // 2. User is admin, OR
      // 3. It's a system template (usuarioID == 'system'), OR
      // 4. User is authenticated (to allow reading shared workouts)
      allow read: if request.auth != null;
      
      // Allow write if user owns the workout, is creator, or is admin
      allow write: if request.auth != null && (
        request.auth.uid == resource.data.usuarioID ||
        request.auth.uid == resource.data.createdByUserId ||
        isAdmin()
      );
      
      // Allow create if:
      // 1. User is creating their own workout, OR
      // 2. Trainer is creating for linked student, OR
      // 3. It's a system template being created (for seeding script)
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.usuarioID ||
        (
          request.auth.uid == request.resource.data.createdByUserId &&
          request.auth.uid != request.resource.data.usuarioID &&
          hasAcceptedTrainerRelation(request.auth.uid, request.resource.data.usuarioID)
        ) ||
        // Transitional fallback for legacy trainer relations created before deterministic IDs.
        (
          request.auth.uid == request.resource.data.createdByUserId &&
          request.auth.uid != request.resource.data.usuarioID &&
          get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.isTrainer == true
        ) ||
        request.resource.data.usuarioID == 'system'
      );
      
      // exercicios subcollection (nested inside treinos)
      match /exercicios/{exercicioId} {
        // Allow any authenticated user to read exercises (for sharing)
        allow read: if request.auth != null;
        
        allow write: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/treinos/$(treinoId)).data.usuarioID ||
          request.auth.uid == get(/databases/$(database)/documents/treinos/$(treinoId)).data.createdByUserId ||
          isAdmin()
        );
        
        allow create: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/treinos/$(treinoId)).data.usuarioID ||
          request.auth.uid == get(/databases/$(database)/documents/treinos/$(treinoId)).data.createdByUserId ||
          get(/databases/$(database)/documents/treinos/$(treinoId)).data.usuarioID == 'system'
        );
      }
    }
    
    // logs collection
    match /logs/{logId} {
      // Allow any authenticated user to read logs (needed for friend's activities tab)
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == resource.data.usuarioID ||
        request.auth.uid == request.resource.data.usuarioID
      );
      allow create: if request.auth.uid == request.resource.data.usuarioID;
    }
    
    // medicoescorporais collection (body measurements)
    match /medicoescorporais/{medicaoId} {
      allow read: if request.auth.uid == resource.data.usuarioID || isAdmin();
      allow write: if request.auth.uid == resource.data.usuarioID || isAdmin();
      allow create: if request.auth.uid == request.resource.data.usuarioID;
      allow delete: if request.auth.uid == resource.data.usuarioID || isAdmin();
    }
    
    // bug_reports collection
    match /bug_reports/{reportId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.usuarioID;
      allow read, update, delete: if isAdmin();
    }
    
    // amizades collection
    match /amizades/{amizadeId} {
      // Anyone authenticated can read friendships to accurately count friend stats
      allow read: if request.auth != null;
      
      // Only the requester can create a new friendship request
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.solicitanteID &&
        request.resource.data.status == 'pendente' &&
        request.resource.data.participantes.hasAll([request.resource.data.solicitanteID, request.resource.data.receptorID]);
        
      // Both participants can update or delete
      allow update, delete: if request.auth != null && (
        request.auth.uid in resource.data.participantes ||
        request.auth.uid == resource.data.solicitanteID ||
        request.auth.uid == resource.data.receptorID
      );
    }

    // trainer_relations collection
    match /trainer_relations/{relationId} {
      // Participants and admins can read relation documents
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.participants || isAdmin()
      );

      // Requester can create a pending request involving themselves
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.requesterId &&
        relationId == trainerRelationId(request.resource.data.trainerId, request.resource.data.studentId) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.participants.hasAll([
          request.resource.data.trainerId,
          request.resource.data.studentId
        ]) &&
        request.resource.data.targetId in request.resource.data.participants;

      // Only target can accept (pending -> accepted)
      allow update: if request.auth != null && (
        isAdmin() ||
        (
          request.auth.uid == resource.data.targetId &&
          resource.data.status == 'pending' &&
          request.resource.data.status == 'accepted' &&
          request.resource.data.trainerId == resource.data.trainerId &&
          request.resource.data.studentId == resource.data.studentId &&
          request.resource.data.requesterId == resource.data.requesterId &&
          request.resource.data.targetId == resource.data.targetId
        )
      );

      // Requester/target/admin can delete a relation (reject/cancel/unlink)
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.requesterId ||
        request.auth.uid == resource.data.targetId ||
        isAdmin()
      );
    }
  }
}
